default_platform(:android)

# ─────────────────────────────────────────────────────────────────────────────
# ANDROID
# ─────────────────────────────────────────────────────────────────────────────
platform :android do

  desc "Run Flutter tests"
  lane :test do
    sh("flutter test")
  end

  desc "Build release APK (split per ABI)"
  lane :build_apk do
    sh("flutter build apk --release --split-per-abi")
  end

  desc "Build release AAB for Play Store"
  lane :build_aab do
    sh("flutter build appbundle --release")
  end

  desc "Deploy to Google Play internal track"
  lane :deploy_internal do
    build_aab
    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      skip_upload_screenshots: true,
      skip_upload_images: true,
    )
  end

  desc "Promote internal → production on Google Play"
  lane :promote_to_production do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      skip_upload_apk: true,
      skip_upload_aab: true,
    )
  end

end

# ─────────────────────────────────────────────────────────────────────────────
# IOS
# ─────────────────────────────────────────────────────────────────────────────
platform :ios do

  desc "Run Flutter tests"
  lane :test do
    sh("flutter test")
  end

  desc "Build iOS release IPA"
  lane :build_ipa do
    sh("flutter build ipa --release --no-codesign")
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
    )
  end

  desc "Deploy to TestFlight"
  lane :deploy_testflight do
    build_ipa
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Deploy to App Store"
  lane :deploy_appstore do
    build_ipa
    deliver(
      submit_for_review: false,
      skip_screenshots: true,
      skip_metadata: false,
    )
  end

end
